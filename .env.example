# Copy this file to `.env`, fill in the values, then regenerate the env code:
#   dart run build_runner build --delete-conflicting-outputs
#
# `.env` is git-ignored (it may hold secrets); this `.env.example` is committed
# so teammates know which variables are required.

# Base URL of the REST API.
API_BASE_URL=https://jsonplaceholder.typicode.com

# Optional API key (obfuscated at build time). Leave empty if unused.
API_KEY=
